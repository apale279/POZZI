rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /patients/{patientId} {
      allow read, write: if request.auth != null;

      match /sheets/{sheetId} {
        allow read, write: if request.auth != null;
      }
    }

    /** Impostazioni globali (mappatura campi IA, valori predefiniti). */
    match /config/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}

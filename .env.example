# Chiave API Google AI Studio (gratis con limiti): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Modello Gemini (opzionale)
GEMINI_MODEL=gemini-2.5-pro

# Porta server analisi locale (default 3001)
API_PORT=3001

# Firebase (Console → Impostazioni progetto → Le tue app → Config SDK)
# Abilita Authentication → Accesso anonimo, e Firestore Database.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
